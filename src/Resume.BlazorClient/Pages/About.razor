@*@page "/about"*@
@using Resume.BlazorClient.TransferObjects

<MudText Typo="Typo.h3" Align="Align.Center" Class="my-4">About</MudText>
<MudDivider />

<MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Start" DisableModifiers="true">

    <MudTimelineItem Size="Size.Medium" Color="Color.Info" Elevation="25">
        <ItemDot>
            <MudIcon Size="Size.Medium" Icon="@Icons.Filled.Person" />
        </ItemDot>
        <ItemContent>
            <MudCard Outlined="true" Elevation="25">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Summary</MudText>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent>
                    <MudText Typo="Typo.body2" Align="Align.Justify">

                        Using C# programming language for 4+ years  with MVC Framework, and interested in .Net 6.
                        @*
                        Code with SOLID principle, especially when using .Net Core.
                        Experienced in basic CI/CD using Azure DevOps for deliver code to production servers.
                        *@

                        Configured task scheduler using Windows Task Scheduler and MS SQL Job, either using console application nor SQL script.
                        Seeking a role with .Net Core solutions.
                        @*, where my skill can be improved by using C# latest features.*@

                    </MudText>
                </MudCardContent>
            </MudCard>
        </ItemContent>
    </MudTimelineItem>

    <MudTimelineItem Size="Size.Medium" Color="Color.Info" Elevation="25">
        <ItemDot>
            <MudIcon Size="Size.Medium" Icon="@Icons.Filled.Star" />
        </ItemDot>
        <ItemContent>
            <MudCard Outlined="true" Elevation="25">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Skills</MudText>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent>
                    <MudGrid>
                        @foreach (var skill in Skills)
                        {
                            <MudItem md="3" sm="6" xs="12">
                                <MudPaper Class="d-flex py-2" Width="100%" Elevation="0">
                                    <MudText Class="flex-none" Typo="Typo.body1">
                                        <MudIcon Class="mr-1" Size="Size.Medium" Color="Color.Info" Icon="@Icons.Filled.Check" />
                                        @skill
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </ItemContent>
    </MudTimelineItem>

</MudTimeline>

<MudDivider />

@code {
    public List<string> Skills => new List<string> {
        "C#",
        "SQL Server",
        //".Net Core",
        "ASP.Net Core",
        "EF Core",
        "Blazor",
        "SignalR",
        "MudBlazor"
    };

    public class ExperienceTransferObject
    {
        public string EmployeeName { get; set; } = null!;
        public string Position { get; set; } = null!;
        public int StartPeriod { get; set; }
        public int EndPeriod { get; set; }
        public string Period => $"({StartPeriod}-{(EndPeriod == 0 ? "Present" : EndPeriod)})";
        public List<string> JobDetail { get; set; } = new List<string>();
    }
}
