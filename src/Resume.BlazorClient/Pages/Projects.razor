@page "/projects"
@using Resume.BlazorClient.TransferObjects

<PageTitle>Projects</PageTitle>

<MudText Typo="Typo.h3" Align="Align.Center" Class="my-4">Projects</MudText>
<MudDivider />

<MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Start" DisableModifiers="true">

    @foreach (var project in ProjectList)
    {
        <MudTimelineItem Size="Size.Medium" Color="Color.Info" Elevation="25">
            <MudCard Outlined="true" Elevation="25">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">@project.Name</MudText>
                </MudCardHeader>
                <MudDivider />
                @*<MudCardMedia Image="https://picsum.photos/900" Height="600" />*@
                <MudCardContent>
                    <MudText Typo="Typo.body2">@project.Overview</MudText>
                    <MudList Clickable="true">
                        <MudListItem Text="Features:" InitiallyExpanded="true">
                            <NestedList>
                                @foreach (var feature in @project.Features)
                                {
                                    <MudListItem Icon="@Icons.Filled.Check" IconColor="Color.Tertiary">
                                        @feature
                                    </MudListItem>
                                }
                            </NestedList>
                        </MudListItem>
                        <MudListItem Text="Tools:" InitiallyExpanded="true">
                            <NestedList>
                                @foreach (var tool in @project.Tools)
                                {
                                    <MudListItem Icon="@Icons.Filled.Check" IconColor="Color.Tertiary">
                                        @tool
                                    </MudListItem>
                                }
                            </NestedList>
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudTimelineItem>
    }
</MudTimeline>

